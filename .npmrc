# TEMPORARY — delete after ~10:05 UTC / 15:35 IST on 2026-07-16.
#
# Expo SDK 57.0.5/57.0.6 shipped 2026-07-15 ~10:00 UTC and sit inside the EAS
# builder's 24h pnpm minimumReleaseAge cooldown, failing the install step. Our
# `~57.0.x` ranges match no older version, so the lockfile cannot resolve under
# the policy at all. Disabling the cooldown is the only way to build until those
# packages age out; leaving it in place opts every future build out of npm
# account-compromise protection.
minimum-release-age=0
