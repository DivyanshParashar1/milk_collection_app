# Copy this file to ".env" and fill in your own values.
# Expo automatically exposes vars prefixed with EXPO_PUBLIC_ to the app.

# From Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: the Razorpay SECRET key is NOT put here — it lives only in the
# Supabase Edge Function secrets:
#   supabase secrets set RAZORPAY_KEY_ID=rzp_test_xxx RAZORPAY_KEY_SECRET=xxx
